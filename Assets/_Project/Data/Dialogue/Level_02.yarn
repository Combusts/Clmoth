title: Setup4
---
//screen = 眼睛显示屏(美术资产变化-1:雪花，2：眼睛，3：笑脸，4：息屏)
//filebox = 拿取任务道具的文件夹
//water = 饮水机（1：模糊不清，2：有文件，3：解体）
//window = 窗户（1：没人，2：有人有密码）
//doorA = 场景中间的门
//door = 进入下一个循环的门
//password = 文件投送口，放任务道具和输密码的地方。

// Loop4
<<declare $Loop4ScreenState = 2>> // 屏幕状态
<<declare $Loop4HasInteractWithFileBox = false>>  // 是否和文件夹对话过
