  m_Script: {fileID: 11500000, guid: 74d2aa410f95da74f8571e6725501b93, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  CodeLines:
  - CodeString:
    - Task.ReturnToStation
    - COMPELETE YOUR WORK!!!
    - while(employed) { work(); }
    - if(dissidence) { compliance(); }
    Index: 0
    VertexColor: {r: 1, g: 1, b: 1, a: 1}
    WaitTime: 0.3
  - CodeString:
    - 'ERROR: UNRECOGNIZED INPUT.SpeechInput.Disable();'
    Index: 1
    VertexColor: {r: 1, g: 1, b: 1, a: 1}
    WaitTime: 0.3
  - CodeString:
    - Navigation.ForceReturn("Main_Office");
    Index: 2
    VertexColor: {r: 1, g: 1, b: 1, a: 1}
    WaitTime: 0.3
  - CodeString:
    - WorkTask.Assign("Urgent_Report"); WorkTask.Execute();
    - While (Task.IsComplete == false) \{ Loop(); \}
    - 'ERROR: TASK_COMPLETION = FALSE'
    - System.Reboot(true); true = FORCE_IMMEDIATE
    Index: 3
    VertexColor: {r: 1, g: 1, b: 1, a: 1}
    WaitTime: 0.3
